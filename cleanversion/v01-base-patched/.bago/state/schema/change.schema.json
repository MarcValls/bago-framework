{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BAGO Change",
  "type": "object",
  "required": [
    "change_id",
    "title",
    "type",
    "severity",
    "status",
    "motivation",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "change_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["architecture", "governance", "migration"]
    },
    "severity": {
      "type": "string",
      "enum": ["patch", "minor", "major", "critical"]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "approved_with_conditions",
        "applied",
        "validated",
        "rejected",
        "unknown"
      ]
    },
    "normalized_status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "approved_with_conditions",
        "applied",
        "validated",
        "rejected",
        "unknown"
      ]
    },
    "legacy_status": {
      "type": ["string", "null"]
    },
    "motivation": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_migration": {
      "type": "boolean"
    },
    "validation_result": {
      "type": "string",
      "enum": ["GO", "GO_WITH_RESERVATIONS", "KO"]
    },
    "source_path": {
      "type": ["string", "null"]
    },
    "raw_markdown_preserved": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
