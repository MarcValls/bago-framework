{
  "version": "1.0",
  "intents": [
    {
      "id": "security_check",
      "name": "Auditoría de seguridad",
      "triggers": [
        "secret",
        "secreto",
        "password",
        "passwd",
        "contraseña",
        "token",
        "api key",
        "hardcode",
        "hardcoded",
        "credencial",
        "credentials",
        "seguridad",
        "security",
        "vulnerable",
        "vulnerabilidad",
        "cve",
        "inject",
        "inyección",
        "xss",
        "sql injection"
      ],
      "tools": [
        "secret-scan",
        "dep-audit"
      ],
      "description": "Escanea secretos hardcodeados y dependencias vulnerables",
      "destructive": false
    },
    {
