{
  "version": "1.0",
  "exclude_dirs": [
    ".bago/state/changes",
    ".bago/state/evidences",
    ".bago/state/sessions",
    ".git",
    ".venv",
    "RELEASE",
    "__pycache__",
    "build",
    "cleanversion",
    "dist",
    "node_modules",
    "sandbox",
    "venv"
  ],
  "flattery_terms": [
    "espectacular",
    "impecable",
    "robust[íi]simo",
    "excelent[ií]simo",
    "de\\s+primer\\s+nivel",
    "nivel\\s+enterprise",
    "world[- ]class",
    "state[- ]of[- ]the[- ]art",
    "perfectamente\\s+orquestad[oa]",
    "sin\\s+igual",
    "magn[íi]fic[oa]",
    "rompedor",
    "asombroso",
    "espectacularmente",
    "incre[íi]ble(?:mente)?",
    "flawless",
    "bulletproof",
    "legendari[oa]",
    "rocket[- ]?ship"
  ],
  "unsubstantiated_absolutes": [
    "\\b100\\s*%\\b",
    "\\btotalmente\\b",
    "\\bcompletamente\\b(?!\\s+opcional)",
    "\\bsiempre\\s+funciona\\b",
    "\\bnunca\\s+falla\\b",
    "\\bsin\\s+fallos?\\b",
    "\\bgarantizad[oa]s?\\b",
    "\\bsin\\s+errores?\\b",
    "\\bcero\\s+errores?\\b",
    "\\bzero[- ]bug\\b",
    "\\b100%\\s+stable\\b",
    "\\bno\\s+tiene\\s+bugs?\\b"
  ],
  "success_washing": [
    "✅\\s*completad[oa]",
    "✅\\s*listo",
    "listo\\s+para\\s+producci[óo]n",
    "production[- ]ready",
    "ready\\s+to\\s+ship",
    "green\\s+across\\s+the\\s+board",
    "todo\\s+OK",
    "todo\\s+verde",
    "all\\s+green",
    "no\\s+hay\\s+nada\\s+pendiente"
  ],
  "future_promises": [
    "\\bse\\s+va\\s+a\\b",
    "\\bpróximamente\\b",
    "\\bproximamente\\b",
    "\\bplanned\\b",
    "\\bto\\s+be\\s+implemented\\b",
    "\\bTBD\\b",
    "\\bfuturo\\s+pr[óo]ximo\\b",
    "\\ben\\s+breve\\b"
  ],
  "done_context_headers": [
    "\\bcompletad[oa]s?\\b",
    "\\bterminad[oa]s?\\b",
    "\\bcerrad[oa]s?\\b",
    "\\bdone\\b",
    "\\bhecho\\b",
    "\\bimplementad[oa]s?\\b",
    "\\bresuelt[oa]s?\\b",
    "\\bfix(?:ed)?\\b"
  ],
  "strong_claims": [
    "\\bPASSED\\b",
    "\\bSTABLE\\b",
    "\\bPRODUCTION[- ]READY\\b"
  ],
  "evidence_hints": [
    "\\.json\\b",
    "\\.md\\b",
    "\\.py\\b",
    "\\.ts\\b",
    "\\.log\\b",
    "\\bevidenc",
    "\\btest",
    "\\bexit[_ ]?code\\b",
    "\\bsha\\b",
    "\\bchecksums?\\b",
    "\\bruntime\\b",
    "\\bcommit\\b",
    "https?://",
    "#L\\d+",
    "\\[.+?\\]\\(.+?\\)"
  ],
  "exempt_patterns": [
    "/templates/",
    "/prompts/",
    "PLANTILLA",
    "plantilla",
    "/canon/",
    "GLOSARIO",
    "/schema/",
    "/migration/legacy/",
    "/agents/",
    "/workflows/",
    "/docs/governance/",
    "/docs/migration/"
  ]
}
