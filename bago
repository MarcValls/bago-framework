#!/usr/bin/env python3
"""
bago — script de activación BAGO
Muestra banner + gestiona comandos rápidos.

Uso:
  ./bago                    → banner + estado (o prompt de arranque si es template)
  ./bago setup              → sincroniza repo_context + instala extensiones Copilot
  ./bago extensions         → gestiona extensiones BAGO (.bago/extensions/)
  ./bago versions           → lista todas las cleanversions disponibles
  ./bago stability          → resumen único de estabilidad (smoke/VM/soak/validadores)
  ./bago dashboard          → pack_dashboard.py
  ./bago ideas              → emit_ideas.py
  ./bago ideas --accept N   → acepta idea N y genera tarea W2
  ./bago task               → muestra la tarea W2 pendiente
  ./bago task --done        → marca la tarea como completada (registra en implemented_ideas.json)
  ./bago session            → abre sesión W2 con preflight pre-rellenado desde handoff
  ./bago session --dry      → muestra args del preflight sin ejecutar
  ./bago efficiency         → medidor de eficiencia inter-versiones
  ./bago cosecha            → cosecha.py
  ./bago detector           → context_detector.py
  ./bago validate           → validate_pack.py  (solo verifica)
  ./bago sync               → sync_pack_metadata.py  (regenera TREE.txt y CHECKSUMS)
  ./bago check              → check_validate_purity.py  (chequeo estático de pureza)
  ./bago dashboard --full   → dashboard extendido
  ./bago health             → health_score.py
  ./bago audit              → audit_v2.py
  ./bago workflow           → workflow_selector.py (interactivo)
  ./bago stale              → stale_detector.py
  ./bago v2                 → v2_close_checklist.py

Instalar como alias global:
  echo 'alias bago="python3 $(pwd)/bago"' >> ~/.zshrc
"""

import json, os, shutil, subprocess, sys, threading, time
from pathlib import Path

BAGO_ROOT = Path(__file__).resolve().parent / ".bago"
TOOLS     = BAGO_ROOT / "tools"

COMMANDS = {
    "dashboard": ["python3", str(TOOLS / "pack_dashboard.py")],
    "ideas":     ["python3", str(TOOLS / "emit_ideas.py")],
    "cosecha":   ["python3", str(TOOLS / "cosecha.py")],
    "detector":  ["python3", str(TOOLS / "context_detector.py")],
    "validate":  ["python3", str(TOOLS / "validate_pack.py")],
    "sync":      ["python3", str(TOOLS / "sync_pack_metadata.py")],
    "check":     ["python3", str(TOOLS / "check_validate_purity.py")],
    "health":    ["python3", str(TOOLS / "health_score.py")],
    "audit":     ["python3", str(TOOLS / "audit_v2.py")],
    "workflow":  ["python3", str(TOOLS / "workflow_selector.py")],
    "stale":     ["python3", str(TOOLS / "stale_detector.py")],
    "v2":        ["python3", str(TOOLS / "v2_close_checklist.py")],
    "task":      ["python3", str(TOOLS / "show_task.py")],
    "stability": ["python3", str(TOOLS / "stability_summary.py")],
    "session":   ["python3", str(TOOLS / "session_opener.py")],
    "efficiency":["python3", str(TOOLS / "efficiency_meter.py")],
}

# ── Extensiones Copilot CLI ────────────────────────────────────────────────────

def _install_extensions(bago_root=None, silent=False):
    """Copia .bago/extensions/*/extension.mjs → .github/extensions/*/extension.mjs"""
    src_base  = (bago_root or BAGO_ROOT) / "extensions"
    repo_root = (bago_root or BAGO_ROOT).parent
    dest_base = repo_root / ".github" / "extensions"

    if not src_base.exists():
        if not silent:
            print("  ℹ  No hay extensiones en .bago/extensions/")
        return []

    installed = []
    for ext_dir in sorted(src_base.iterdir()):
        src_file = ext_dir / "extension.mjs"
        if not src_file.exists():
            continue
        dest_dir  = dest_base / ext_dir.name
        dest_file = dest_dir / "extension.mjs"
        dest_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(str(src_file), str(dest_file))
        installed.append(ext_dir.name)

    if installed and not silent:
        for name in installed:
            print(f"  🔌 Extensión instalada: {name}")
    return installed

def _cmd_extensions():
    """Lista extensiones disponibles e instala si hay cambios."""
    src_base = BAGO_ROOT / "extensions"
    if not src_base.exists() or not any(src_base.iterdir()):
        print("  No hay extensiones BAGO en .bago/extensions/")
        return

    print()
    print("  ┌──────────────────────────────────────────────┐")
    print("  │  BAGO · Extensiones Copilot CLI              │")
    print("  └──────────────────────────────────────────────┘")
    for ext_dir in sorted(src_base.iterdir()):
        if (ext_dir / "extension.mjs").exists():
            dest = BAGO_ROOT.parent / ".github" / "extensions" / ext_dir.name / "extension.mjs"
            status = "✅ instalada" if dest.exists() else "⚠️  pendiente"
            print(f"  🔌 {ext_dir.name:30s} {status}")
    print()
    print("  Reinstalar: bago setup")
    print()

# ── Helpers de estado ──────────────────────────────────────────────────────────

def _read_state(bago_root=None):
    f = (bago_root or BAGO_ROOT) / "state" / "global_state.json"
    if not f.exists():
        return {}
    with open(f) as fh:
        return json.load(fh)

def _write_state(state, bago_root=None):
    f = (bago_root or BAGO_ROOT) / "state" / "global_state.json"
    with open(f, "w") as fh:
        json.dump(state, fh, indent=2, ensure_ascii=False)
        fh.write("\n")

def _set_mode(mode, bago_root=None):
    s = _read_state(bago_root)
    s["distribution_mode"] = mode
    _write_state(s, bago_root)

def _is_template_seed():
    return _read_state().get("distribution_mode") == "template_seed"

# ── Scaffold de proyecto nuevo ─────────────────────────────────────────────────

def _scaffold_project(dest_input):
    src = BAGO_ROOT.parent
    dest = Path(dest_input.strip()).expanduser().resolve() if dest_input.strip() else src

    if dest == src:
        print()
        print("  ⚠️  Estás a punto de inicializar BAGO en el propio directorio del framework.")
        print(f"     {dest}")
        print()
        print("  BAGO está diseñado para gobernar un proyecto externo, no a sí mismo.")
        print("  Usa esta opción solo si realmente quieres evolucionar el framework.")
        print()
        try:
            confirm = input("  ¿Confirmar igualmente? [s/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if confirm != "s":
            print("\n  Cancelado. Vuelve a ejecutar y elige otro directorio.\n")
            return False
        _set_mode("project_active")
        _auto_sync(src)
        _install_extensions(silent=True)
        print(f"\n  ✅ Proyecto inicializado en: {dest}\n")
        return True

    try:
        dest.relative_to(src)
        print("  ⚠  El destino no puede estar dentro del directorio fuente.")
        return False
    except ValueError:
        pass

    if dest.exists() and any(dest.iterdir()):
        print(f"  ⚠  El directorio ya existe y no está vacío:\n     {dest}")
        return False

    print(f"\n  📦 Copiando pack a: {dest}")
    dest.mkdir(parents=True, exist_ok=True)

    shutil.copytree(str(BAGO_ROOT), str(dest / ".bago"))
    shutil.copy2(str(src / "bago"), str(dest / "bago"))
    os.chmod(str(dest / "bago"), 0o755)
    if (src / "Makefile").exists():
        shutil.copy2(str(src / "Makefile"), str(dest / "Makefile"))

    _set_mode("project_active", dest / ".bago")

    subprocess.run(
        ["python3", str(dest / "bago"), "setup"],
        cwd=str(dest)
    )

    print(f"\n  ✅ Proyecto listo en: {dest}")
    print(f"  ▶  cd \"{dest}\" && python3 bago\n")
    return True


def _candidate_dirs():
    """Devuelve hasta 4 directorios candidatos para el nuevo proyecto:
    el CWD (si no es el framework) y hasta 3 padres del framework."""
    framework_dir = BAGO_ROOT.parent
    cwd = Path.cwd()
    seen = set()
    candidates = []

    for d in ([cwd] if cwd != framework_dir else []) + list(framework_dir.parents)[:4]:
        if d not in seen and d != framework_dir:
            seen.add(d)
            candidates.append(d)
        if len(candidates) == 4:
            break
    return candidates


# ── Helpers de git ─────────────────────────────────────────────────────────────

def _git_short_hash(cwd=None):
    """Devuelve el hash corto del HEAD actual, o None."""
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--short", "HEAD"],
            cwd=str(cwd or BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _git_describe(cwd=None):
    """Devuelve git describe --tags --always, o None."""
    try:
        r = subprocess.run(
            ["git", "describe", "--tags", "--always"],
            cwd=str(cwd or BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _has_remote_updates():
    """Devuelve True si origin/master tiene commits que no están en local."""
    try:
        subprocess.run(
            ["git", "fetch", "--quiet"],
            cwd=str(BAGO_ROOT.parent), capture_output=True, text=True, timeout=6
        )
        r = subprocess.run(
            ["git", "rev-list", "HEAD..origin/master", "--count"],
            cwd=str(BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.returncode == 0 and r.stdout.strip() not in ("", "0")
    except Exception:
        return False


# ── Helpers de arranque ────────────────────────────────────────────────────────

def _git_remote_url():
    """Devuelve la URL del remote origin si existe, o None."""
    try:
        r = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            cwd=str(BAGO_ROOT.parent),
            capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _update_framework():
    """Actualiza el framework mostrando banner, progreso animado y versión final."""
    framework_dir = BAGO_ROOT.parent
    old_desc = _git_describe(framework_dir) or _git_short_hash(framework_dir) or "desconocida"

    subprocess.run(
        ["python3", str(TOOLS / "bago_banner.py")],
        cwd=str(framework_dir)
    )

    print(f"  Versión actual : {old_desc}")
    print()

    done_event = threading.Event()

    def _spin():
        frames = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        i = 0
        while not done_event.is_set():
            filled = (i * 2) % 21
            bar = "█" * filled + "░" * (20 - filled)
            print(
                f"\r  {frames[i % len(frames)]} [{bar}] Descargando desde GitHub...",
                end="", flush=True
            )
            i += 1
            time.sleep(0.08)
        print("\r" + " " * 65 + "\r", end="", flush=True)

    t = threading.Thread(target=_spin, daemon=True)
    t.start()

    r = subprocess.run(
        ["git", "pull", "--ff-only"],
        cwd=str(framework_dir), capture_output=True, text=True
    )
    done_event.set()
    t.join(timeout=1)

    new_desc = _git_describe(framework_dir) or _git_short_hash(framework_dir) or "desconocida"

    if r.returncode == 0:
        if old_desc == new_desc:
            print("  ✅ Ya tenías la versión más reciente.")
            print(f"     Versión: {new_desc}")
        else:
            print("  ✅ Framework actualizado.")
            print(f"     {old_desc}  →  {new_desc}")
        print()
        return True
    else:
        print("  ⚠  No se pudo actualizar.")
        if r.stderr.strip():
            print(f"     {r.stderr.strip()}")
        print("     Ejecuta: git pull origin master\n")
        return False


def _pick_project_dir():
    """Pide nombre del proyecto y directorio padre.
    Devuelve la ruta completa (str) o None si cancela."""
    print()
    print("  ─── Nuevo proyecto ─────────────────────────────────────")
    print()

    # El nombre del proyecto es obligatorio
    name = ""
    while not name:
        try:
            name = input("  Nombre del proyecto: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if not name:
            print("  ⚠  El nombre no puede estar vacío.")

    candidates = _candidate_dirs()
    print()
    print("  ¿Dónde crear el proyecto?\n")
    for i, d in enumerate(candidates, 1):
        print(f"  [{i}] {d}{os.sep}{name}")
    print("  [M] Otra ruta base (escribirla)")
    print()

    try:
        sel = input(f"  Elige [1-{len(candidates)}/M]: ").strip().upper()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if sel.isdigit() and 1 <= int(sel) <= len(candidates):
        parent = candidates[int(sel) - 1]
        return str(parent / name)
    elif sel == "M":
        try:
            base = input("  Ruta base: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if base:
            return str(Path(base).expanduser().resolve() / name)
        print("  ⚠  Ruta vacía, cancelado.\n")
        return None
    else:
        print("\n  Opción no válida.\n")
        return None


def _startup_update_check():
    """Comprueba actualizaciones silenciosamente y ofrece actualizar si las hay."""
    if not _git_remote_url():
        return
    if not _has_remote_updates():
        return
    current = _git_describe() or _git_short_hash() or "actual"
    print()
    print(f"  ⚡ Hay una actualización disponible  (local: {current})")
    print()
    try:
        ans = input("  ¿Actualizar ahora? [S/n]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if ans in ("", "s", "si", "sí", "y", "yes"):
        _update_framework()
        sys.exit(0)


# ── Prompt de arranque ─────────────────────────────────────────────────────────

def _prompt_mode():
    """Mostrado la primera vez que se ejecuta una cleanversion."""
    remote = _git_remote_url()

    # Comprobación silenciosa de actualizaciones disponibles
    updates_available = False
    if remote:
        print("  Comprobando actualizaciones...", end="", flush=True)
        updates_available = _has_remote_updates()
        print("\r" + " " * 35 + "\r", end="", flush=True)

    print()
    print("  ┌─────────────────────────────────────────────────┐")
    print("  │  BAGO · Arranque del framework                  │")
    if updates_available:
        print("  ├─────────────────────────────────────────────────┤")
        print("  │  [!] Nueva version disponible en GitHub         │")
    print("  ├─────────────────────────────────────────────────┤")
    print("  │  [1] Seguir con esta versión                    │")
    if remote:
        if updates_available:
            print("  │  [2] Actualizar framework  <- recomendado       │")
        else:
            print("  │  [2] Actualizar framework  (git pull)           │")
        print("  │  [3] Nuevo proyecto                             │")
        print("  │  [4] Evolucionar el framework BAGO              │")
        max_opt = 4
    else:
        print("  │  [2] Nuevo proyecto                             │")
        print("  │  [3] Evolucionar el framework BAGO              │")
        max_opt = 3
    print("  └─────────────────────────────────────────────────┘")
    print()

    try:
        choice = input(f"  Elige [1-{max_opt}]: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    # Normalizar opciones según si hay remote o no
    if not remote and choice == "2":
        choice = "_new_project"
    elif not remote and choice == "3":
        choice = "_evolve"
    elif remote and choice == "3":
        choice = "_new_project"
    elif remote and choice == "4":
        choice = "_evolve"

    if choice == "1":
        _set_mode("framework_host")
        print("\n  ✅ Continuando con la versión actual.\n")
        return "banner"

    elif choice == "2" and remote:
        success = _update_framework()
        return "done" if success else "error"

    elif choice == "_new_project":
        dest_input = _pick_project_dir()
        if dest_input is None:
            return "invalid"
        return "done" if _scaffold_project(dest_input) else "error"

    elif choice == "_evolve":
        _set_mode("framework_host")
        print("\n  ✅ Modo framework activado.\n")
        return "banner"

    else:
        print(f"\n  Opción no válida. Usa 1-{max_opt}.\n")
        return "invalid"

# ── bago versions ─────────────────────────────────────────────────────────────

def _cmd_versions():
    """Lista todas las cleanversions encontradas junto al script."""
    cv_dir = Path(__file__).resolve().parent.parent / "cleanversion"
    if not cv_dir.exists():
        cv_dir = Path(__file__).resolve().parent / "cleanversion"
    if not cv_dir.exists():
        print("  No se encontró directorio cleanversion/")
        return

    entries = sorted(d for d in cv_dir.iterdir() if d.is_dir() and not d.name.startswith('.'))
    if not entries:
        print("  No hay cleanversions.")
        return

    print()
    print("  ┌─────────────────────────────────────────────────────────────┐")
    print("  │  BAGO · Cleanversions disponibles                          │")
    print("  └─────────────────────────────────────────────────────────────┘")

    for d in entries:
        info_file  = d / "VERSION_INFO.json"
        state_file = d / ".bago" / "state" / "global_state.json"

        info  = json.loads(info_file.read_text())  if info_file.exists()  else {}
        state = json.loads(state_file.read_text()) if state_file.exists() else {}

        chg_dir   = d / ".bago" / "state" / "changes"
        chg_count = len(list(chg_dir.glob("BAGO-CHG-*.json"))) if chg_dir.exists() else 0

        slug   = info.get("slug", d.name)
        name   = info.get("display_name", "—")
        desc   = info.get("description", "")
        mode   = state.get("distribution_mode") or "—"
        script = info.get("bago_script", "—")
        notes  = info.get("notes", "")

        print()
        print(f"  📦 {slug}")
        print(f"     {name}")
        print(f"     {desc}")
        print(f"     mode={mode} | CHG={chg_count} | bago={script}")
        if notes:
            print(f"     💡 {notes}")

    print()

# ── Auto-sync silencioso ───────────────────────────────────────────────────────

def _auto_sync(cwd=None):
    try:
        subprocess.run(
            ["python3", str(TOOLS / "repo_context_guard.py"), "sync"],
            cwd=str(cwd or BAGO_ROOT.parent),
            capture_output=True,
            timeout=5
        )
    except Exception:
        pass

# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    # Prompt de primera ejecución (solo sin args y con TTY)
    if not args and sys.stdin.isatty() and _is_template_seed():
        result = _prompt_mode()
        if result in ("done", "error", "invalid"):
            sys.exit(1 if result == "error" else 0)
        # result == "banner" → continúa al banner normal

    # En arranque normal (no template_seed), comprobar si hay actualizaciones
    elif not args and sys.stdin.isatty():
        _startup_update_check()

    # validate y health son comandos de solo lectura — no tocar state/
    _READ_ONLY_CMDS = {"validate", "health"}
    if not (args and args[0].lower() in _READ_ONLY_CMDS):
        _auto_sync()

    if not args:
        subprocess.run(
            ["python3", str(TOOLS / "bago_banner.py")],
            cwd=str(BAGO_ROOT.parent)
        )
        return

    cmd = args[0].lower()
    rest = args[1:]

    if cmd == "setup":
        subprocess.run(
            ["python3", str(TOOLS / "repo_context_guard.py"), "sync"],
            cwd=str(BAGO_ROOT.parent)
        )
        _install_extensions()
    elif cmd == "extensions":
        _cmd_extensions()
    elif cmd == "versions":
        _cmd_versions()
    elif cmd in COMMANDS:
        subprocess.run(COMMANDS[cmd] + rest, cwd=str(BAGO_ROOT.parent))
    elif cmd in ("help", "--help", "-h"):
        subprocess.run(
            ["python3", str(TOOLS / "bago_banner.py"), "--mini"],
            cwd=str(BAGO_ROOT.parent)
        )
        print("  Comandos disponibles:")
        print("    bago setup")
        print("    bago extensions")
        print("    bago versions")
        for k in COMMANDS:
            print(f"    bago {k}")
        print()
    else:
        print(f"  Comando desconocido: '{cmd}'")
        print("  Usa: bago help")
        sys.exit(1)


if __name__ == "__main__":
    main()
