# Python
__pycache__/
*.py[cod]
*.pyo

# macOS — metadatos del sistema (pendrive)
.DS_Store
.DS_Store?
._*
.Spotlight-V100/
.fseventsd/
.Trashes/
.VolumeIcon.icns

# Windows — metadatos del sistema (pendrive)
System\ Volume\ Information/
$RECYCLE.BIN/
autorun.inf
Thumbs.db
desktop.ini

# BAGO — binarios Ollama (demasiado grandes para git, se regeneran con bago doctor --fix)
.bago/bin/

# BAGO — modelos LLM (pesos descargados, no se versionan)
.bago/.models/

# BAGO — runtime
.bago/state/llm_server.pid
.bago/state/bago_context.log
.bago/state/events.jsonl

# BAGO — session data (private)
.bago/state/sessions/
.bago/state/changes/
.bago/state/evidences/
!.bago/state/sessions/.gitkeep
!.bago/state/changes/.gitkeep
!.bago/state/evidences/.gitkeep

# BAGO — volatile runtime files (generated on demand, not canonical)
# Generated on `bago setup` / sync-cmds; excluded from CHECKSUMS in sync_pack_metadata.py.
.bago/state/repo_context.json
.bago/snapshots/
.bago/state/research/


# Editor
.vscode/
.idea/
*.swp
*.DS_Store
whatsapp_config.json
*.secret.json
notify_config.json
whatsapp_config.json
*.secret.json

# State privado (no versionar)
.bago/state/chat_history.json
.bago/state/tareas_telegram.json

# Backups y builds
.bago/tools/*.bak
.bago/tools/ImageStudio.spec
.bago/tools/build_exe.bat
.bago/tools/image_studio/
.bago/ImageStudio/
.bago/image_studio/

