            print("  │  [3] Actualizar framework  <- recomendado       │")
        else:
            print("  │  [3] Actualizar framework  (git pull)           │")
        print("  │  [4] Modo desarrollo del framework              │")
        max_opt = 4
    else:
        print("  │  [3] Modo desarrollo del framework              │")
        max_opt = 3
    print("  └─────────────────────────────────────────────────┘")
    print()

    try:
        choice = input(f"  Elige [1-{max_opt}]: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    _evolve_opt = "4" if remote else "3"
    _update_opt = "3" if remote else None

    if choice == "1":
        # Proyecto existente — pedir ruta directamente
        print()
        print("  Escribe la ruta al directorio de tu proyecto.")
        print("  (puede ser absoluta o relativa al directorio actual)")
        print()
        try:
            ruta = input("  Ruta del proyecto: ").strip()
        except (EOFError, KeyboardInterrupt):
            print(); sys.exit(0)
        if not ruta:
            print("  ⚠  Ruta vacía, cancelado.\n")
            return "invalid"
        dest = Path(ruta).expanduser().resolve()
        if dest == framework_dir:
            print()
            print("  ⚠  Esa es la carpeta del propio framework BAGO.")
            print("  Para desarrollar el framework usa la opción correspondiente.")
            print()
            return "invalid"
        return "done" if _scaffold_project(str(dest), is_existing=True) else "error"

    elif choice == "2":
        # Proyecto nuevo — pedir nombre y dónde crearlo
        print()
        name = ""
        while not name:
            try:
                name = input("  Nombre del proyecto: ").strip()
            except (EOFError, KeyboardInterrupt):
                print(); sys.exit(0)
            if not name:
                print("  ⚠  El nombre no puede estar vacío.")
        print()
        print("  ¿Dónde crear el proyecto?")
        print(f"  (Enter para crear junto al framework: {framework_dir.parent / name})")
        print()
        try:
            base = input("  Directorio base [Enter = junto al framework]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print(); sys.exit(0)
        parent = Path(base).expanduser().resolve() if base else framework_dir.parent
        dest = parent / name
        if dest == framework_dir:
            print("  ⚠  Ese nombre coincide con el directorio del framework.\n")
            return "invalid"
        return "done" if _scaffold_project(str(dest), is_existing=False) else "error"

    elif choice == _update_opt and remote:
        success = _update_framework()
        return "done" if success else "error"

    elif choice == _evolve_opt:
        print()
        print("  ℹ  Modo desarrollo del framework BAGO.")
        print("  Solo recomendado si vas a contribuir al propio framework.")
        print()
        try:
            confirm = input("  ¿Confirmar? [s/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print(); sys.exit(0)
        if confirm != "s":
            print("\n  Cancelado. Vuelve a ejecutar para elegir un proyecto.\n")
            return "invalid"
        _set_mode("framework_host")
        print("\n  ✅ Modo desarrollo del framework activado.\n")
        return "banner"

    else:
        print(f"\n  Opción no válida. Usa 1-{max_opt}.\n")
        return "invalid"


def _cmd_versions():
    """Lista todas las cleanversions encontradas junto al script."""
    cv_dir = Path(__file__).resolve().parent.parent / "cleanversion"
    if not cv_dir.exists():
        cv_dir = Path(__file__).resolve().parent / "cleanversion"
    if not cv_dir.exists():
        print("  No se encontró directorio cleanversion/")
        return

    entries = sorted(d for d in cv_dir.iterdir() if d.is_dir() and not d.name.startswith('.'))
    if not entries:
        print("  No hay cleanversions.")
        return

    print()
    print("  ┌─────────────────────────────────────────────────────────────┐")
    print("  │  BAGO · Cleanversions disponibles                          │")
    print("  └─────────────────────────────────────────────────────────────┘")

    for d in entries:
        info_file  = d / "VERSION_INFO.json"
        state_file = d / ".bago" / "state" / "global_state.json"

        info  = json.loads(info_file.read_text())  if info_file.exists()  else {}
        state = json.loads(state_file.read_text()) if state_file.exists() else {}

        chg_dir   = d / ".bago" / "state" / "changes"
        chg_count = len(list(chg_dir.glob("BAGO-CHG-*.json"))) if chg_dir.exists() else 0

        slug   = info.get("slug", d.name)
        name   = info.get("display_name", "—")
        desc   = info.get("description", "")
        mode   = state.get("distribution_mode") or "—"
        script = info.get("bago_script", "—")
        notes  = info.get("notes", "")

        print()
        print(f"  📦 {slug}")
        print(f"     {name}")
        print(f"     {desc}")
        print(f"     mode={mode} | CHG={chg_count} | bago={script}")
        if notes:
            print(f"     💡 {notes}")

    print()

# ── Auto-sync silencioso ───────────────────────────────────────────────────────

def _auto_sync(cwd=None):
    try:
        subprocess.run(
            ["python3", str(TOOLS / "repo_context_guard.py"), "sync"],
            cwd=str(cwd or BAGO_ROOT.parent),
            capture_output=True,
            timeout=5
        )
    except Exception:
        pass

# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    # Gestión del modo template_seed
    if not args and _is_template_seed():
        if sys.stdin.isatty():
            # Terminal real: mostrar menú interactivo
            result = _prompt_mode()
            if result in ("done", "error", "invalid"):
                sys.exit(1 if result == "error" else 0)
            # result == "banner" → continúa al banner normal
        else:
            # Sin TTY (script, agente, pipe): avisar y salir — no mostrar banner
            # como si BAGO estuviera configurado cuando no lo está
            print()
            print("  ⚠  BAGO está en modo template_seed (clon sin configurar).")
            print("  Ejecuta  python3 bago  en un terminal interactivo para configurarlo.")
            print()
            sys.exit(1)

    # En arranque normal (no template_seed), comprobar si hay actualizaciones
    elif not args and sys.stdin.isatty():
        _startup_update_check()

    # validate y health son comandos de solo lectura — no tocar state/
    _READ_ONLY_CMDS = {"validate", "health"}
    if not (args and args[0].lower() in _READ_ONLY_CMDS):
        _auto_sync()

    if not args:
        subprocess.run(
            ["python3", str(TOOLS / "bago_banner.py")],
            cwd=str(BAGO_ROOT.parent)
        )
        return

    cmd = args[0].lower()
    rest = args[1:]

    if cmd == "setup":
        subprocess.run(
            ["python3", str(TOOLS / "repo_context_guard.py"), "sync"],
            cwd=str(BAGO_ROOT.parent)
        )
        _install_extensions()
    elif cmd == "extensions":
        _cmd_extensions()
    elif cmd == "versions":
        _cmd_versions()
    elif cmd in COMMANDS:
        subprocess.run(COMMANDS[cmd] + rest, cwd=str(BAGO_ROOT.parent))
    elif cmd in ("help", "--help", "-h"):
        subprocess.run(
            ["python3", str(TOOLS / "bago_banner.py"), "--mini"],
            cwd=str(BAGO_ROOT.parent)
        )
        print("  Comandos disponibles:")
        print("    bago setup")
        print("    bago extensions")
        print("    bago versions")
        for k in COMMANDS:
            print(f"    bago {k}")
        print()
    else:
        print(f"  Comando desconocido: '{cmd}'")
        print("  Usa: bago help")
        sys.exit(1)


if __name__ == "__main__":
    main()
