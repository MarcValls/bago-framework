# ── Extensiones Copilot CLI ────────────────────────────────────────────────────

def _install_extensions(bago_root=None, silent=False):
    """Copia .bago/extensions/*/extension.mjs → .github/extensions/*/extension.mjs"""
    src_base  = (bago_root or BAGO_ROOT) / "extensions"
    repo_root = (bago_root or BAGO_ROOT).parent
    dest_base = repo_root / ".github" / "extensions"

    if not src_base.exists():
        if not silent:
            print("  ℹ  No hay extensiones en .bago/extensions/")
        return []

    installed = []
    for ext_dir in sorted(src_base.iterdir()):
        src_file = ext_dir / "extension.mjs"
        if not src_file.exists():
            continue
        dest_dir  = dest_base / ext_dir.name
        dest_file = dest_dir / "extension.mjs"
        dest_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(str(src_file), str(dest_file))
        installed.append(ext_dir.name)

    if installed and not silent:
        for name in installed:
            print(f"  🔌 Extensión instalada: {name}")
    return installed

def _cmd_extensions():
    """Lista extensiones disponibles e instala si hay cambios."""
    src_base = BAGO_ROOT / "extensions"
    if not src_base.exists() or not any(src_base.iterdir()):
        print("  No hay extensiones BAGO en .bago/extensions/")
        return

    print()
    print("  ┌──────────────────────────────────────────────┐")
    print("  │  BAGO · Extensiones Copilot CLI              │")
    print("  └──────────────────────────────────────────────┘")
    for ext_dir in sorted(src_base.iterdir()):
        if (ext_dir / "extension.mjs").exists():
            dest = BAGO_ROOT.parent / ".github" / "extensions" / ext_dir.name / "extension.mjs"
            status = "✅ instalada" if dest.exists() else "⚠️  pendiente"
            print(f"  🔌 {ext_dir.name:30s} {status}")
    print()
    print("  Reinstalar: bago setup")
    print()

# ── Helpers de estado ──────────────────────────────────────────────────────────

def _read_state(bago_root=None):
    f = (bago_root or BAGO_ROOT) / "state" / "global_state.json"
    if not f.exists():
        return {}
    with open(f) as fh:
        return json.load(fh)

def _write_state(state, bago_root=None):
    f = (bago_root or BAGO_ROOT) / "state" / "global_state.json"
    with open(f, "w") as fh:
        json.dump(state, fh, indent=2, ensure_ascii=False)
        fh.write("\n")

def _set_mode(mode, bago_root=None):
    s = _read_state(bago_root)
    s["distribution_mode"] = mode
    _write_state(s, bago_root)

def _is_template_seed():
    return _read_state().get("distribution_mode") == "template_seed"

# ── Scaffold de proyecto nuevo ─────────────────────────────────────────────────

def _scaffold_project(dest_input, is_existing=False):
    src = BAGO_ROOT.parent
    dest = Path(dest_input.strip()).expanduser().resolve() if dest_input.strip() else src

    if dest == src:
        print()
        print("  ⚠️  Estás a punto de inicializar BAGO en el propio directorio del framework.")
        print(f"     {dest}")
        print()
        print("  BAGO está diseñado para gobernar un proyecto externo, no a sí mismo.")
        print("  Usa esta opción solo si realmente quieres evolucionar el framework.")
        print()
        try:
            confirm = input("  ¿Confirmar igualmente? [s/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if confirm != "s":
            print("\n  Cancelado. Vuelve a ejecutar y elige otro directorio.\n")
            return False
        _set_mode("project_active")
        _auto_sync(src)
        _install_extensions(silent=True)
        print(f"\n  ✅ Proyecto inicializado en: {dest}\n")
        return True

    try:
        dest.relative_to(src)
        print("  ⚠  El destino no puede estar dentro del directorio fuente.")
        return False
    except ValueError:
        pass

    # ── Proyecto existente ────────────────────────────────────────────────────
    if is_existing:
        if not dest.exists():
            print(f"  ⚠  El directorio no existe:\n     {dest}")
            return False

        ctx = _detect_project_context(dest)

        if ctx["has_bago"]:
            print(f"\n  ⚠  Este directorio ya tiene BAGO inicializado (.bago/).")
            print(f"     {dest}")
            try:
                confirm = input("  ¿Reinicializar de todas formas? [s/N]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print(); sys.exit(0)
            if confirm != "s":
                print("\n  Cancelado.\n")
                return False

        if ctx["files_found"]:
            _show_context_box(ctx)
            try:
                use_ctx = input("  ¿Usar este contexto para inicializar BAGO? [S/n]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print(); sys.exit(0)
            if use_ctx == "n":
                ctx = None
        else:
            print(f"\n  ℹ  No se detectó contenido reconocible en: {dest}")
            ctx = None

        shutil.copytree(str(BAGO_ROOT), str(dest / ".bago"), dirs_exist_ok=True)
        shutil.copy2(str(src / "bago"), str(dest / "bago"))
        os.chmod(str(dest / "bago"), 0o755)
        if (src / "Makefile").exists() and not (dest / "Makefile").exists():
            shutil.copy2(str(src / "Makefile"), str(dest / "Makefile"))

        _set_mode("project_active", dest / ".bago")

        # Escribir contexto detectado en global_state
        if ctx:
            _write_context_to_state(ctx, dest / ".bago")

        subprocess.run(["python3", str(dest / "bago"), "setup"], cwd=str(dest))
        print(f"\n  ✅ BAGO inicializado en proyecto existente: {dest}")
        print(f"  ▶  cd \"{dest}\" && python3 bago\n")
        return True

    # ── Proyecto nuevo (directorio vacío) ─────────────────────────────────────
    if dest.exists() and any(dest.iterdir()):
        print(f"  ⚠  El directorio ya existe y no está vacío:\n     {dest}")
        print(f"     Si quieres inicializar BAGO en un proyecto existente, elige [2].")
        return False

    print(f"\n  📦 Copiando pack a: {dest}")
    dest.mkdir(parents=True, exist_ok=True)

    shutil.copytree(str(BAGO_ROOT), str(dest / ".bago"))
    shutil.copy2(str(src / "bago"), str(dest / "bago"))
    os.chmod(str(dest / "bago"), 0o755)
    if (src / "Makefile").exists():
        shutil.copy2(str(src / "Makefile"), str(dest / "Makefile"))

    _set_mode("project_active", dest / ".bago")

    subprocess.run(
        ["python3", str(dest / "bago"), "setup"],
        cwd=str(dest)
    )

    print(f"\n  ✅ Proyecto listo en: {dest}")
    print(f"  ▶  cd \"{dest}\" && python3 bago\n")
    return True


def _write_context_to_state(ctx, bago_root=None):
    """Escribe el contexto detectado del proyecto en global_state.json."""
    s = _read_state(bago_root)
    s["project_context"] = {
        "name":        ctx.get("name", ""),
        "description": ctx.get("description", ""),
        "tech":        ctx.get("tech", []),
        "has_docs":    ctx.get("has_docs", False),
        "has_git":     ctx.get("has_git", False),
        "detected_files": ctx.get("files_found", []),
    }
    if ctx.get("name"):
        s["project_name"] = ctx["name"]
    _write_state(s, bago_root)


def _detect_project_context(path):
    """Escanea path buscando proyecto o documentación existente.
    Devuelve dict con name, description, tech, has_docs, has_git, has_bago, files_found."""
    p = Path(path)
    ctx = {
        "name":        p.name,
        "description": "",
        "tech":        [],
        "has_docs":    False,
        "has_git":     False,
        "has_bago":    (p / ".bago").exists(),
        "files_found": [],
    }

    if (p / ".git").exists():
        ctx["has_git"] = True
        ctx["files_found"].append(".git/")

    # README → nombre y descripción
    for readme in ["README.md", "README.rst", "README.txt", "readme.md"]:
        if (p / readme).exists():
            ctx["files_found"].append(readme)
            try:
                text = (p / readme).read_text(encoding="utf-8", errors="ignore")
                lines = [l.strip() for l in text.splitlines() if l.strip()]
                for l in lines[:8]:
                    if l.startswith("#") and not ctx["name"].startswith(p.name):
                        ctx["name"] = l.lstrip("#").strip()
                    elif not ctx["description"] and l and not l.startswith("#"):
                        ctx["description"] = l[:120]
                        break
            except Exception:
                pass
            break

    # Stack tecnológico
    _TECH_FILES = {
        "package.json":    ("Node.js",       lambda p: json.loads((p).read_text())),
        "pyproject.toml":  ("Python",        None),
        "requirements.txt":("Python",        None),
        "setup.py":        ("Python",        None),
        "Cargo.toml":      ("Rust",          None),
        "go.mod":          ("Go",            None),
        "pom.xml":         ("Java/Maven",    None),
        "build.gradle":    ("Java/Gradle",   None),
        "Gemfile":         ("Ruby",          None),
        "composer.json":   ("PHP",           None),
        "CMakeLists.txt":  ("C/C++",         None),
    }
    for fname, (tech, reader) in _TECH_FILES.items():
        if (p / fname).exists():
            if tech not in ctx["tech"]:
                ctx["tech"].append(tech)
            ctx["files_found"].append(fname)
            if reader and not ctx["description"]:
                try:
                    data = reader(p / fname)
                    if not ctx["name"] or ctx["name"] == p.name:
                        ctx["name"] = data.get("name", ctx["name"])
                    ctx["description"] = ctx["description"] or data.get("description", "")
                except Exception:
                    pass

    # Carpeta docs
    for doc_dir in ["docs", "doc", "documentation", "Docs", "wiki"]:
        if (p / doc_dir).is_dir():
            ctx["has_docs"] = True
            ctx["files_found"].append(f"{doc_dir}/")
            break

    return ctx


def _show_context_box(ctx):
    """Imprime un cuadro resumen del contexto detectado."""
    print()
    print("  ┌─────────────────────────────────────────────────┐")
    print("  │  Proyecto detectado                             │")
    print("  ├─────────────────────────────────────────────────┤")
    name_line = f"  Nombre:  {ctx['name']}"
    print(f"  │  {name_line:<47}│")
    if ctx["description"]:
        desc = ctx["description"][:44]
        print(f"  │  Desc:   {desc:<47}│")
    if ctx["tech"]:
        tech_str = ", ".join(ctx["tech"])[:44]
        print(f"  │  Stack:  {tech_str:<47}│")
    flags = []
    if ctx["has_git"]:   flags.append("git")
    if ctx["has_docs"]:  flags.append("docs")
    if ctx["has_bago"]:  flags.append("⚠ ya tiene .bago/")
    if flags:
        print(f"  │  Extra:  {', '.join(flags):<47}│")
    found = ", ".join(ctx["files_found"][:5])
    if len(ctx["files_found"]) > 5:
        found += f" +{len(ctx['files_found'])-5}"
    print(f"  │  Archivos: {found:<45}│")
    print("  └─────────────────────────────────────────────────┘")
    print()


def _candidate_dirs():
    """Devuelve hasta 4 directorios candidatos para el nuevo proyecto:
    el CWD (si no es el framework) y hasta 3 padres del framework."""
    framework_dir = BAGO_ROOT.parent
    cwd = Path.cwd()
    seen = set()
    candidates = []

    for d in ([cwd] if cwd != framework_dir else []) + list(framework_dir.parents)[:4]:
        if d not in seen and d != framework_dir:
            seen.add(d)
            candidates.append(d)
        if len(candidates) == 4:
            break
    return candidates


# ── Helpers de git ─────────────────────────────────────────────────────────────

def _git_short_hash(cwd=None):
    """Devuelve el hash corto del HEAD actual, o None."""
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--short", "HEAD"],
            cwd=str(cwd or BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _git_describe(cwd=None):
    """Devuelve git describe --tags --always, o None."""
    try:
        r = subprocess.run(
            ["git", "describe", "--tags", "--always"],
            cwd=str(cwd or BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _has_remote_updates():
    """Devuelve True si origin/master tiene commits que no están en local."""
    try:
        subprocess.run(
            ["git", "fetch", "--quiet"],
            cwd=str(BAGO_ROOT.parent), capture_output=True, text=True, timeout=6
        )
        r = subprocess.run(
            ["git", "rev-list", "HEAD..origin/master", "--count"],
            cwd=str(BAGO_ROOT.parent), capture_output=True, text=True
        )
        return r.returncode == 0 and r.stdout.strip() not in ("", "0")
    except Exception:
        return False


# ── Helpers de arranque ────────────────────────────────────────────────────────

def _git_remote_url():
    """Devuelve la URL del remote origin si existe, o None."""
    try:
        r = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            cwd=str(BAGO_ROOT.parent),
            capture_output=True, text=True
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None


def _update_framework():
    """Actualiza el framework mostrando banner, progreso animado y versión final."""
    framework_dir = BAGO_ROOT.parent
    old_desc = _git_describe(framework_dir) or _git_short_hash(framework_dir) or "desconocida"

    subprocess.run(
        ["python3", str(TOOLS / "bago_banner.py")],
        cwd=str(framework_dir)
    )

    print(f"  Versión actual : {old_desc}")
    print()

    done_event = threading.Event()

    def _spin():
        frames = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        i = 0
        while not done_event.is_set():
            filled = (i * 2) % 21
            bar = "█" * filled + "░" * (20 - filled)
            print(
                f"\r  {frames[i % len(frames)]} [{bar}] Descargando desde GitHub...",
                end="", flush=True
            )
            i += 1
            time.sleep(0.08)
        print("\r" + " " * 65 + "\r", end="", flush=True)

    t = threading.Thread(target=_spin, daemon=True)
    t.start()

    r = subprocess.run(
        ["git", "pull", "--ff-only"],
        cwd=str(framework_dir), capture_output=True, text=True
    )
    done_event.set()
    t.join(timeout=1)

    new_desc = _git_describe(framework_dir) or _git_short_hash(framework_dir) or "desconocida"

    if r.returncode == 0:
        if old_desc == new_desc:
            print("  ✅ Ya tenías la versión más reciente.")
            print(f"     Versión: {new_desc}")
        else:
            print("  ✅ Framework actualizado.")
            print(f"     {old_desc}  →  {new_desc}")
        print()
        return True
    else:
        print("  ⚠  No se pudo actualizar.")
        if r.stderr.strip():
            print(f"     {r.stderr.strip()}")
        print("     Ejecuta: git pull origin master\n")
        return False


def _pick_project_dir():
    """Pide tipo (nuevo/existente), nombre/ruta y directorio padre.
    Devuelve (ruta_completa: str, is_existing: bool) o (None, False) si cancela."""
    print()
    print("  ─── Inicializar BAGO en un proyecto ────────────────────")
    print()
    print("  [1] Proyecto nuevo   (crear directorio vacío)")
    print("  [2] Proyecto existente (directorio con contenido)")
    print()
    try:
        tipo = input("  Elige [1/2]: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if tipo == "2":
        # ── Proyecto existente ────────────────────────────────────
        candidates = _candidate_dirs()
        print()
        print("  ¿Cuál es el directorio del proyecto?\n")
        for i, d in enumerate(candidates, 1):
            print(f"  [{i}] {d}")
        print("  [M] Escribir ruta manualmente")
        print()
        try:
            sel = input(f"  Elige [1-{len(candidates)}/M]: ").strip().upper()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if sel.isdigit() and 1 <= int(sel) <= len(candidates):
            return str(candidates[int(sel) - 1]), True
        elif sel == "M":
            try:
                ruta = input("  Ruta del proyecto: ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
            if ruta:
                return str(Path(ruta).expanduser().resolve()), True
            print("  ⚠  Ruta vacía, cancelado.\n")
            return None, False
        else:
            print("\n  Opción no válida.\n")
            return None, False

    elif tipo == "1":
        # ── Proyecto nuevo ────────────────────────────────────────
        name = ""
        while not name:
            try:
                name = input("  Nombre del proyecto: ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
            if not name:
                print("  ⚠  El nombre no puede estar vacío.")

        candidates = _candidate_dirs()
        print()
        print("  ¿Dónde crear el proyecto?\n")
        for i, d in enumerate(candidates, 1):
            print(f"  [{i}] {d}{os.sep}{name}")
        print("  [M] Otra ruta base (escribirla)")
        print()
        try:
            sel = input(f"  Elige [1-{len(candidates)}/M]: ").strip().upper()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if sel.isdigit() and 1 <= int(sel) <= len(candidates):
            parent = candidates[int(sel) - 1]
            return str(parent / name), False
        elif sel == "M":
            try:
                base = input("  Ruta base: ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
            if base:
                return str(Path(base).expanduser().resolve() / name), False
            print("  ⚠  Ruta vacía, cancelado.\n")
            return None, False
        else:
            print("\n  Opción no válida.\n")
            return None, False
    else:
        print("\n  Opción no válida.\n")
        return None, False


def _startup_update_check():
    """Comprueba actualizaciones silenciosamente y ofrece actualizar si las hay."""
    if not _git_remote_url():
        return
    if not _has_remote_updates():
        return
    current = _git_describe() or _git_short_hash() or "actual"
    print()
    print(f"  ⚡ Hay una actualización disponible  (local: {current})")
    print()
    try:
        ans = input("  ¿Actualizar ahora? [S/n]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if ans in ("", "s", "si", "sí", "y", "yes"):
        _update_framework()
        sys.exit(0)


