{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BAGO Workflow Meta",
  "type": "object",
  "required": ["id", "objective", "roles_minimum", "closure"],
  "properties": {
    "id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "roles_minimum": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "closure": {
      "type": "string"
    },
    "incidents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "description": "Esquema mínimo de metadatos para workflows cuando se quieran representar fuera del markdown operativo."
}
